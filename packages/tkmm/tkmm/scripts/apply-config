#!/bin/bash

# TKMM Configuration Script

# This sets the wallpaper to a random splash image (displayed while waiting for TKMM to load)
# It creates a randomized queue to ensure we don't get the same splash images multiple times in a row

SPLASHDIR="/usr/share/tkmm/splashes"
QUEUE="/storage/.cache/tkmm_splash_queue"
list="/run/tkmm-splash-all.$$"

if [ -f "$QUEUE" ] && [ -s "$QUEUE" ]; then
  img=$(head -n 1 "$QUEUE" | tr -d '\r')
  tail -n +2 "$QUEUE" >"${QUEUE}.t" && mv "${QUEUE}.t" "$QUEUE"
  fbsetbg -f "$img"
else
  find "$SPLASHDIR" -maxdepth 1 -type f -iname '*.png' 2>/dev/null | sort >"$list"
  n=$(wc -l <"$list" | tr -d ' \t\r')
  if [ -z "$n" ] || [ "$n" -eq 0 ] 2>/dev/null; then
    rm -f "$list"
  elif [ "$n" -eq 1 ] 2>/dev/null; then
    img=$(head -n 1 "$list")
    rm -f "$QUEUE"
    rm -f "$list"
    fbsetbg -f "$img"
  else
    awk 'BEGIN{srand()} {print rand() "\t" $0}' "$list" | sort -n | cut -f2- >"$QUEUE"
    img=$(head -n 1 "$QUEUE" | tr -d '\r')
    tail -n +2 "$QUEUE" >"${QUEUE}.t" && mv "${QUEUE}.t" "$QUEUE"
    rm -f "$list"
    fbsetbg -f "$img"
  fi
fi

# This part is used to define wether we're in a development environment or not
# If this is a user environment, we use the Tkmm binary from the OS image

rm /run/tkmm_launch.sh
echo '#!/bin/sh' >  /run/tkmm_launch.sh
if  [ -f /storage/.tkmm/Tkmm ]; then
  echo 'exec /storage/.tkmm/Tkmm "$@"' >> /run/tkmm_launch.sh
else
  echo 'exec /usr/share/tkmm/Tkmm "$@"' >> /run/tkmm_launch.sh
fi
chmod +x /run/tkmm_launch.sh

# This part sets the volume and Avalonia UI scale based on the config file in tkmm/config.ini
# It would be much better to bind the volume buttons for this but sound is only ever played when taking a screenshot anyway

DEFAULT_VOLUME=40
DEFAULT_SCALE_PERCENT=100

SCALE_PERCENT=$(read-config "Display" "scale" "$DEFAULT_SCALE_PERCENT")
VOLUME_PERCENT=$(read-config "Audio" "volume" "$DEFAULT_VOLUME")
SOUND_CARD_NAME=$(cat /storage/.cache/sound_card)

if ! [ "$SCALE_PERCENT" -ge 50 ] || ! [ "$SCALE_PERCENT" -le 200 ] || ! [ "$SCALE_PERCENT" -eq "$SCALE_PERCENT" ] 2>/dev/null; then
    SCALE_PERCENT=$DEFAULT_SCALE_PERCENT
    echo "Config Error: Scale value is invalid or empty, defaulting to: '$SCALE_PERCENT'"
fi

if ! [ "$VOLUME_PERCENT" -ge 0 ] || ! [ "$VOLUME_PERCENT" -le 100 ] || ! [ "$VOLUME_PERCENT" -eq "$VOLUME_PERCENT" ] 2>/dev/null; then
    VOLUME_PERCENT=$DEFAULT_VOLUME
    echo "Config Error: Volume value is invalid or empty, defaulting to: '$VOLUME_PERCENT'"
fi

if [ "$SCALE_PERCENT" -le 99 ]; then
    SCALE_FACTOR="0.${SCALE_PERCENT}"
else
    SCALE_FACTOR="${SCALE_PERCENT:0:1}.${SCALE_PERCENT:1}"
fi
echo "AVALONIA_GLOBAL_SCALE_FACTOR=$SCALE_FACTOR" > /storage/.cache/env_variables

# set the sound card to configured volume
amixer -c "$SOUND_CARD_NAME" set 'x Speaker' "${VOLUME_PERCENT}%" >/dev/null 2>&1
